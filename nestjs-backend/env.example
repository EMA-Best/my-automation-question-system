# ============================================
# 数据库配置
# ============================================
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=question_db

# ============================================
# 服务器配置
# ============================================
PORT=3005

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ============================================
# DeepSeek AI 配置
# ============================================
# DeepSeek API Key（必填）
# 获取方式：访问 https://www.deepseek.com/ 注册并创建 API Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API 地址（可选，默认值如下）
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# DeepSeek 模型名称（可选，默认值如下）
# 可选值：deepseek-chat, deepseek-coder 等
DEEPSEEK_MODEL=deepseek-chat

# 温度参数（可选，0-2之间，默认 0.7）
# 值越高，生成的内容越随机；值越低，生成的内容越确定
DEEPSEEK_TEMPERATURE=0.7

# 最大 token 数（可选，默认 2000）
# 控制生成内容的长度，建议范围：1000-4000
DEEPSEEK_MAX_TOKENS=2000

